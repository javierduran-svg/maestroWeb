# Copia este archivo como .env en la raiz del proyecto (desarrollo local).
#
# =============================================================================
# INFRAESTRUCTURA (un .env por entorno: local, beta, produccion)
# =============================================================================

# PostgreSQL local: docker compose up -d
DATABASE_URL=postgresql://maestroweb:maestroweb@localhost:5432/maestroweb
# Sin Docker, omita DATABASE_URL y usara SQLite (solo pruebas rapidas):
# DATABASE_URL=sqlite:///gestion_proyectos.db

FLASK_SECRET_KEY=

# Cifra credenciales SII/banco al guardarlas en BD. Generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# Admin de desarrollo (solo si SEED_DEV_ADMIN=1, default): javier@b-green.cl
# DEV_ADMIN_PASSWORD=Nathalie
# SEED_DEV_ADMIN=1

# Respaldo UF si no hay valor en BD ni mindicador.cl
# UF_REFERENCIA_CLP=38000

# =============================================================================
# POR EMPRESA -> BASE DE DATOS + UI (no archivos .env por empresa)
# =============================================================================
# Cada empresa tiene sus credenciales en tablas empresa_sii_config y
# empresa_banco_conexiones. Configurar en la app: Finanzas -> SII / Bancos.
#
# La seccion siguiente es SOLO un atajo de desarrollo: si la BD esta vacia,
# al primer arranque se copian a la empresa 1. No usar en produccion con dump.

# SII / SimpleAPI (https://www.simpleapi.cl)
# SII_API_KEY=
# SII_RUT_EMISOR=
# SII_USUARIO=
# SII_PASSWORD=
# SII_AMBIENTE=0

# Fintoc (https://docs.fintoc.com/docs/api-keys)
# FINTOC_API_KEY=
# FINTOC_LINK_TOKEN=
# FINTOC_ACCOUNT_ID=

# Fallback PDF liquidaciones si no hay datos en BD (opcional)
# EMPRESA_RAZON_SOCIAL=
# EMPRESA_DIRECCION=

# Produccion en Hetzner: ver .env.production.example (solo infra, sin SII/Fintoc).
