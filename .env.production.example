# Copie como .env en el servidor (Hetzner). Solo configuracion del despliegue.
# Las credenciales SII, bancos y datos de cada empresa van en la BASE DE DATOS
# (Finanzas en la app), no en este archivo.
#
# Generar secretos en el servidor:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Dominio (registro A -> IP del VPS) ---
APP_DOMAIN=erp.bgreenchile.cl
ACME_EMAIL=admin@bgreenchile.cl

# --- PostgreSQL (solo red interna Docker) ---
POSTGRES_USER=maestroweb
POSTGRES_PASSWORD=
POSTGRES_DB=maestroweb

# --- Flask / cifrado ---
FLASK_SECRET_KEY=
# Misma clave que en local si restaura un dump con credenciales cifradas.
SECRET_ENCRYPTION_KEY=

# No resetear contrasenas ni sembrar admin al arrancar.
SEED_DEV_ADMIN=0

# --- Gunicorn (opcional) ---
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
